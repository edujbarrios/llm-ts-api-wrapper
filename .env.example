# Environment configuration for llm7-wrapper
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# Base URL of your OpenAI-compatible API
# llm7.io example:
LLM_BASE_URL=https://api.llm7.io/v1

# Your API key / bearer token
LLM_API_KEY=your-api-key-here

# ------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------

# Default model to use when not specified per-request
LLM_DEFAULT_MODEL=gpt-4o-mini

# Request timeout in milliseconds (default: 30000)
LLM_TIMEOUT_MS=30000

# How many times to retry transient errors (default: 2)
LLM_MAX_RETRIES=3

# Base back-off delay between retries in ms (default: 1000)
LLM_RETRY_BACKOFF_MS=1000
