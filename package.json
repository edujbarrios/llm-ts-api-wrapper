{
  "name": "llm-ts-api-wrapper",
  "version": "1.0.0",
  "description": "A TypeScript wrapper for any OpenAI-compatible API (llm7.io, OpenAI, Azure OpenAI, Groq, etc.) — also known as llm7-wrapper",
  "author": "Eduardo J. Barrios <edujbarrios@outlook.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run clean && npm run build",
    "example:capital": "node dist/examples/capital-of-spain.js"
  },
  "keywords": [
    "llm",
    "openai",
    "llm7",
    "llm-ts-api-wrapper",
    "llm7-wrapper",
    "ai",
    "typescript",
    "wrapper",
    "chat",
    "completions",
    "openai-compatible"
  ],
  "aliases": ["llm7-wrapper", "llm-ts-api-wrapper"],
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.5",
    "rimraf": "^5.0.5",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
